# LIVCK Server Monitoring Agent - optional environment overrides.
#
# Copy this file to /etc/livck-agent/agent.env to activate it. The systemd unit
# loads it with "EnvironmentFile=-/etc/livck-agent/agent.env" (the leading '-'
# means it is optional). Restart the service after editing:
#
#     sudo cp /etc/livck-agent/agent.env.example /etc/livck-agent/agent.env
#     sudo systemctl restart livck-agent
#
# If this file holds proxy credentials, tighten its permissions:
#
#     sudo chmod 0600 /etc/livck-agent/agent.env
#
# ASCII only.

# --- Corporate / egress proxy (DACH networks) --------------------------------
# The agent makes outbound HTTPS to ingest.livck.cloud and app.livck.cloud only.
# Point it at your egress proxy if direct 443 is blocked.
#HTTPS_PROXY=http://proxy.internal.example:3128
#HTTP_PROXY=http://proxy.internal.example:3128
#NO_PROXY=localhost,127.0.0.1,.internal.example

# --- Advanced overrides (normally unnecessary) -------------------------------
# The enroll handshake persists the ingest URL; set these only for self-hosted
# or staging control planes. Leaving them unset uses the public defaults.
#LIVCK_INGEST_URL=https://ingest.livck.cloud
#LIVCK_CONFIG_URL=https://app.livck.cloud
